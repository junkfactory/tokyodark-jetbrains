<idea-plugin>
  <id>tokyodark.islands</id>
  <name>Tokyo Dark Islands Theme</name>
  <version>0.1.0</version>
  <vendor>Theme Bot</vendor>

  <description>Tokyo Dark Islands theme and bundled editor scheme</description>

  <depends>com.intellij.modules.platform</depends>

  <!-- Broad compatibility for development: allows newer IDE builds to load this plugin during runIde iterations -->
  <idea-version since-build="261.0" until-build="*" />

  <extensions defaultExtensionNs="com.intellij">
    <themeProvider id="tokyo.dark.islands" path="/themes/TokyoDarkIslands.theme.json"/>
    <bundledColorScheme path="/colorSchemes/TokyoDarkIslands.xml"/>
  </extensions>

</idea-plugin>
